# ============================================================
# REQUIRED ENVIRONMENT VARIABLES FOR PRODUCTION
# ============================================================

# NextAuth Configuration (REQUIRED for production)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# Supabase Configuration (REQUIRED)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin Authentication (REQUIRED)
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=your_secure_admin_password

# Email Configuration (Resend - REQUIRED for email notifications)
RESEND_API_KEY=your_resend_api_key

# Google reCAPTCHA (REQUIRED for form submission protection)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# ============================================================
# OPTIONAL ENVIRONMENT VARIABLES
# ============================================================

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://wisedellcollege.run.place
NEXT_PUBLIC_SITE_NAME=WISEDELL ACADEMY

# Email Configuration (SMTP - optional fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@wisdellacademy.co.zw

# WhatsApp Configuration
NEXT_PUBLIC_WHATSAPP_NUMBER=263778022980

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
